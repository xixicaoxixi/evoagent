# EvoAgent LLM Provider Configuration
# Priority: openai > anthropic > kimi > glm > deepseek (customizable via PROVIDER_PRIORITY)

# Provider Priority (comma-separated, first = highest priority)
# Available: openai, anthropic, kimi, glm, deepseek
PROVIDER_PRIORITY=openai,anthropic,kimi,glm,deepseek

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5.6

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Kimi / Moonshot (https://platform.moonshot.cn)
KIMI_API_KEY=sk-your-kimi-api-key
KIMI_MODEL=kimi-k2.6

# GLM / ZhipuAI (https://open.bigmodel.cn)
GLM_API_KEY=your-glm-api-key
GLM_MODEL=glm-5.1

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-pro
