{
  "name": "evoagent-ts",
  "version": "0.1.0",
  "description": "Self-evolving multi-agent system in TypeScript. Agents learn from task outcomes, generating and retiring evolution rules to continuously improve.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "check:dev": "tsc --noEmit -p tsconfig.dev.json",
    "test": "bun test",
    "dev": "bun run src/index.ts",
    "build": "tsc",
    "build:dev": "tsc -p tsconfig.dev.json",
    "audit": "npm audit --production --audit-level=moderate",
    "audit:pack": "npm pack --dry-run 2>&1",
    "audit:secrets": "grep -rn 'sk-ant-api03\\|AKIA[0-9A-Z]\\{16\\}\\|ghp_[a-zA-Z0-9]\\{36\\}' src/ || echo 'No secrets found'",
    "audit:refs": "grep -rn 'claude-code\\|openclaw\\|HackerOne' src/ || echo 'No external references found'",
    "prepublishOnly": "bun run check && bun test",
    "prepack": "npm run build && node scripts/audit-pack.js"
  },
  "dependencies": {
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
